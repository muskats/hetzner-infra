#cloud-config
apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  name: flux-system
  namespace: flux-system
spec:
  interval: 1m
  url: https://github.com/muskats/hetzner-platform
  ref:
    branch: main
---
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: hetzner-platform
  namespace: flux-system
spec:
  interval: 10m
  path: ./clusters/hetzner-k3s
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
  wait: true
