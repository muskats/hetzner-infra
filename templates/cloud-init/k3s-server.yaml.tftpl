#cloud-config
package_update: true
package_upgrade: true
packages:
  - curl
  - ca-certificates

write_files:
  - path: /etc/rancher/k3s/config.yaml
    permissions: "0644"
    content: |
      token: ${cluster_token}
      node-ip: ${node_ip}
      advertise-address: ${node_ip}
      write-kubeconfig-mode: "0644"

  - path: /tmp/flux-bootstrap.yaml
    permissions: "0644"
    content: |
${flux_bootstrap_yaml}

runcmd:
  - [ sh, -c, "set -euxo pipefail; curl -fsSL https://get.k3s.io -o /root/get-k3s.sh; INSTALL_K3S_VERSION=${k3s_version} sh /root/get-k3s.sh server" ]
  - [ sh, -c, "set -euxo pipefail; curl -fsSL https://tailscale.com/install.sh | sh && tailscale up --auth-key='${tailscale_auth_key}'" ]
  - [ sh, -c, "set -euxo pipefail; until k3s kubectl get nodes >/dev/null 2>&1; do sleep 5; done" ]
  - [ sh, -c, "set -euxo pipefail; curl -fsSL https://fluxcd.io/install.sh | bash" ]
  - [ sh, -c, "set -euxo pipefail; flux install --export | k3s kubectl apply -f -" ]
  - [ sh, -c, "set -euxo pipefail; k3s kubectl apply -f /tmp/flux-bootstrap.yaml" ]
  